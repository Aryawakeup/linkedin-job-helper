{
  "manifest_version": 3,
  "name": "LinkedIn Job Helper — Dutch & Resume Match",
  "version": "1.0.0",
  "description": "Annotates LinkedIn job postings: flags whether Dutch is required and scores the match against your resume.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
